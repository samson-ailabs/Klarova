# Copy to .env and fill in. The .env file is git-ignored.

# Model gateway (OpenRouter — one key, model selected by string).
OPENROUTER_API_KEY=

# Embeddings (OpenRouter has no embedder; inject a hosted one).
# e.g. OpenAI text-embedding-3-small
OPENAI_API_KEY=

# Observability (from the copilot onward — Ship 2+).
LANGSMITH_API_KEY=
